# ── YieldFabric service URLs ─────────────────────────────────────────
# Copy to `.env` and adjust. The dev defaults below match a local
# YieldFabric stack; production values for the hosted platform:
#
#   REACT_APP_AUTH_SERVICE_URL=https://auth.yieldfabric.com
#   REACT_APP_PAYMENTS_SERVICE_URL=https://pay.yieldfabric.com
#   REACT_APP_API_URL=https://pay.yieldfabric.com
#   REACT_APP_GRAPHQL_GATEWAY_URL=https://api.yieldfabric.com/graphql

# Read by the wallet-SDK (sign-in, tokens, profile, keys, group
# delegation, the incoming-payments inbox + signature drawer).
REACT_APP_AUTH_SERVICE_URL=http://localhost:3000
REACT_APP_PAYMENTS_SERVICE_URL=http://localhost:3002
REACT_APP_API_URL=http://localhost:3002

# Read by this app.
#   Gateway → federated GraphQL: the DMS deal-flow namespace
#             (`dealFlow { … }`) plus cross-service reads (rent-schedule
#             contracts, the entity directory, the asset catalog).
#   The on-chain payment MUTATIONS (collect / exchange / settle) and the
#   message-status + balance REST endpoints go payments-direct, derived
#   from REACT_APP_PAYMENTS_SERVICE_URL above (see src/config.ts).
REACT_APP_GRAPHQL_GATEWAY_URL=http://localhost:4000/graphql

# CRA defaults to :3000, which collides with the local YF auth service
# (and :3001/:3002/:4000 are agents/payments/gateway, :3020 is the chat
# example). Pin the dev server somewhere free.
PORT=3023

# The in-app "docs ↗" tutorial links point here (see src/docs.ts).
# Override for a self-hosted docs site.
# REACT_APP_DOCS_BASE_URL=https://yieldfabric.com
